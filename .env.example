# Local Docker Compose PostgreSQL runs on host port 5433.
DATABASE_URL="postgresql://pulseops:pulseops@127.0.0.1:5433/pulseops?schema=public"

# Local Docker Compose Redis.
# For Render or other hosted Redis providers, prefer REDIS_URL.
REDIS_URL=
REDIS_HOST=localhost
REDIS_PORT=6379

# Replace this before sharing a deployed API.
JWT_SECRET=replace-with-a-long-random-value

# Used by the API CORS config.
FRONTEND_URL=http://localhost:3000

# Used by the Next.js frontend. In deployment, set this to the public API URL.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

BACKEND_PORT=4000

# Optional. Leave blank locally unless you want to test real email delivery.
RESEND_API_KEY=
EMAIL_FROM="PulseOps <alerts@example.com>"
