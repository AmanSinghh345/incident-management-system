generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MonitorStatus {
  UP
  DOWN
  DEGRADED
  PAUSED
}

enum CheckStatus {
  SUCCESS
  FAILURE
}

enum IncidentStatus {
  OPEN
  ACKNOWLEDGED
  RESOLVED
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum NotificationChannel {
  EMAIL
  WEBHOOK
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  CANCELLED
}

model User {
  id            String           @id @default(cuid())
  name          String
  email         String           @unique
  passwordHash  String
  workspaceSlug String           @unique
  monitors      Monitor[]
  incidentNotes IncidentUpdate[]
  assignedIncidents Incident[]        @relation("IncidentAssignee")
  notifications Notification[]
  webhookEndpoints WebhookEndpoint[]
  ownedWorkspaceMembers WorkspaceMember[] @relation("WorkspaceOwner")
  workspaceMemberships WorkspaceMember[] @relation("WorkspaceMemberUser")
  sentWorkspaceInvites WorkspaceInvite[] @relation("WorkspaceInviteInviter")
  receivedWorkspaceInvites WorkspaceInvite[] @relation("WorkspaceInviteAcceptedUser")
  workspaceAuditLogs AuditLog[] @relation("WorkspaceAuditWorkspaceOwner")
  actorAuditLogs AuditLog[] @relation("WorkspaceAuditActor")
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
}

model Monitor {
  id              String        @id @default(cuid())
  name            String
  url             String
  method          String        @default("GET")
  expectedStatusCode Int        @default(200)
  timeoutSeconds  Int           @default(5)
  isPublic        Boolean       @default(true)
  publicName      String?
  showUrl         Boolean       @default(false)
  intervalSeconds Int           @default(60)
  failureThreshold Int          @default(3)
  status          MonitorStatus @default(PAUSED)
  isActive        Boolean       @default(true)
  ownerId         String
  owner           User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  checkResults    CheckResult[]
  incidents       Incident[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([ownerId])
}

model CheckResult {
  id             String      @id @default(cuid())
  monitorId      String
  monitor        Monitor     @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  status         CheckStatus
  statusCode     Int?
  responseTimeMs Int?
  errorMessage   String?
  checkedAt      DateTime    @default(now())

  @@index([monitorId, checkedAt])
}

model Incident {
  id          String           @id @default(cuid())
  title       String
  status      IncidentStatus   @default(OPEN)
  severity    IncidentSeverity @default(HIGH)
  assignedToId String?
  assignedTo   User?            @relation("IncidentAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)
  monitorId   String
  monitor     Monitor          @relation(fields: [monitorId], references: [id], onDelete: Cascade)
  updates     IncidentUpdate[]
  notifications Notification[]
  startedAt   DateTime         @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([monitorId, status])
  @@index([assignedToId])
}

model IncidentUpdate {
  id         String   @id @default(cuid())
  incidentId String
  incident   Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  message    String
  createdAt  DateTime @default(now())

  @@index([incidentId])
}

model Notification {
  id         String              @id @default(cuid())
  channel    NotificationChannel
  status     NotificationStatus  @default(PENDING)
  recipient  String
  subject    String
  message    String
  userId     String?
  user       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  incidentId String?
  incident   Incident?           @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  sentAt     DateTime?
  createdAt  DateTime            @default(now())

  @@index([userId])
  @@index([incidentId])
}

model WebhookEndpoint {
  id        String   @id @default(cuid())
  name      String
  url       String
  secret    String   @default(uuid())
  isActive  Boolean  @default(true)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model WorkspaceMember {
  id               String        @id @default(cuid())
  workspaceOwnerId String
  workspaceOwner   User          @relation("WorkspaceOwner", fields: [workspaceOwnerId], references: [id], onDelete: Cascade)
  userId           String
  user             User          @relation("WorkspaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)
  role             WorkspaceRole @default(MEMBER)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@unique([workspaceOwnerId, userId])
  @@index([userId])
}

model WorkspaceInvite {
  id               String                @id @default(cuid())
  workspaceOwnerId String
  workspaceOwner   User                  @relation("WorkspaceInviteInviter", fields: [workspaceOwnerId], references: [id], onDelete: Cascade)
  email            String
  role             WorkspaceRole         @default(MEMBER)
  status           WorkspaceInviteStatus @default(PENDING)
  acceptedUserId   String?
  acceptedUser     User?                 @relation("WorkspaceInviteAcceptedUser", fields: [acceptedUserId], references: [id], onDelete: SetNull)
  acceptedAt       DateTime?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  @@index([workspaceOwnerId, status])
  @@index([email, status])
}

model AuditLog {
  id               String   @id @default(cuid())
  workspaceOwnerId String
  workspaceOwner   User     @relation("WorkspaceAuditWorkspaceOwner", fields: [workspaceOwnerId], references: [id], onDelete: Cascade)
  actorId          String?
  actor            User?    @relation("WorkspaceAuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  action           String
  entityType       String
  entityId         String?
  summary          String
  metadata         Json?
  createdAt        DateTime @default(now())

  @@index([workspaceOwnerId, createdAt])
  @@index([actorId])
  @@index([entityType, entityId])
}
